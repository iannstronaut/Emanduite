{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Emanduite",
  "version": "0.1.0",
  "identifier": "dev.emanduite.workspace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Emanduite Workspace", "width": 1280, "height": 800, "minWidth": 900, "minHeight": 600, "decorations": true }],
    "security": { "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost" }
  },
  "bundle": { "active": false }
}
